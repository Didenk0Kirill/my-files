import pygame

pygame.init()

win = pygame.display.set_mode((500, 500))
pygame.display.set_caption("Game 3 - ПР15 Shooting")

# Завантаження фону
bg_image = pygame.image.load('bg.jpg')
bg = pygame.transform.scale(bg_image, (500, 500))

x = 50
y = 425
width = 40
height = 60
speed = 5

isJump = False
jumpCount = 10

# Змінна для визначення напрямку останнього руху (1 - вправо, -1 - вліво)
lastMove = 1 

# Клас снаряда
class snaryad():
    def __init__(self, x, y, radius, color, facing):
        self.x = x
        self.y = y
        self.radius = radius
        self.color = color
        self.facing = facing
        self.vel = 8 * facing # Швидкість польоту снаряда

    def draw(self, win):
        pygame.draw.circle(win, self.color, (self.x, self.y), self.radius)

def drawWindow():
    win.blit(bg, (0, 0))
    # Малюємо гравця
    pygame.draw.rect(win, (0, 0, 255), (x, y, width, height))
    
    # Малюємо всі снаряди зі списку
    for bullet in bullets:
        bullet.draw(win)
        
    pygame.display.update()

bullets = [] # Список для збереження об'єктів-снарядів
run = True
while run:
    pygame.time.delay(30)

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            run = False

    # Логіка польоту снарядів: видаляємо, якщо вилетіли за екран
    for bullet in bullets:
        if bullet.x < 500 and bullet.x > 0:
            bullet.x += bullet.vel
        else:
            bullets.pop(bullets.index(bullet))

    keys = pygame.key.get_pressed()

    # Стрільба на клавішу F
    if keys[pygame.K_f]:
        if len(bullets) < 5: # Обмеження кількості снарядів на екрані
            bullets.append(snaryad(round(x + width // 2), round(y + height // 2), 5, (255, 0, 0), lastMove))

    if keys[pygame.K_LEFT] and x > 5:
        x -= speed
        lastMove = -1
    elif keys[pygame.K_RIGHT] and x < 500 - width - 5:
        x += speed
        lastMove = 1

    if not (isJump):
        if keys[pygame.K_SPACE]:
            isJump = True
    else:
        if jumpCount >= -10:
            if jumpCount < 0:
                y += (jumpCount ** 2) / 2
            else:
                y -= (jumpCount ** 2) / 2
            jumpCount -= 1
        else:
            isJump = False
            jumpCount = 10

    drawWindow()

pygame.quit()
