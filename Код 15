import pygame
import random

pygame.init()

win_width = 600
win_height = 450
win = pygame.display.set_mode((win_width, win_height))
pygame.display.set_caption("Space Battle: Meteors & Asteroids")

bg = pygame.image.load('bg.jpg')
bg = pygame.transform.scale(bg, (win_width, win_height))

class Player:
    def __init__(self, x, y, width, height):
        self.x = x
        self.y = y
        self.width = width
        self.height = height
        self.vel = 7
        self.hitbox = (self.x, self.y, self.width, self.height)

    def draw(self, win):
        pygame.draw.rect(win, (0, 255, 0), (self.x, self.y, self.width, self.height))
        self.hitbox = (self.x, self.y, self.width, self.height)

class Meteor:
    def __init__(self, x, y, width, height):
        self.x = x
        self.y = y
        self.width = width
        self.height = height
        self.vel = random.randint(3, 6) # Швидкість падіння
        self.hitbox = (self.x, self.y, self.width, self.height)

    def draw(self, win):
        self.move()
        pygame.draw.rect(win, (200, 200, 200), (self.x, self.y, self.width, self.height))
        self.hitbox = (self.x, self.y, self.width, self.height)

    def move(self):
        if self.y < win_height:
            self.y += self.vel # Рух вниз
        else:
            self.y = -50 # Повернення вгору
            self.x = random.randint(0, win_width - self.width)

class Asteroid:
    def __init__(self, x, y, width, height):
        self.x = x
        self.y = y
        self.width = width
        self.height = height
        self.vel = random.randint(1, 3) # Астероїди повільніші
        self.hitbox = (self.x, self.y, self.width, self.height)

    def draw(self, win):
        self.move()
        pygame.draw.rect(win, (100, 100, 100), (self.x, self.y, self.width, self.height))
        self.hitbox = (self.x, self.y, self.width, self.height)

    def move(self):
        if self.y < win_height:
            self.y += self.vel
        else:
            self.y = -100
            self.x = random.randint(0, win_width - self.width)

# Створення об'єктів
spaceship = Player(270, 380, 60, 40)
m1 = Meteor(random.randint(0, 550), -50, 40, 40)
a1 = Asteroid(random.randint(0, 550), -150, 60, 60)

def redrawGameWindow():
    win.blit(bg, (0, 0))
    spaceship.draw(win)
    m1.draw(win)
    a1.draw(win)
    pygame.display.update()

run = True
while run:
    pygame.time.delay(30)
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            run = False

    keys = pygame.key.get_pressed()
    if keys[pygame.K_LEFT] and spaceship.x > spaceship.vel:
        spaceship.x -= spaceship.vel
    elif keys[pygame.K_RIGHT] and spaceship.x < win_width - spaceship.width - spaceship.vel:
        spaceship.x += spaceship.vel

    redrawGameWindow()

pygame.quit()
